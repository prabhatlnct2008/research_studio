# =============================================================================
# Studio — Vercel environment variables
# -----------------------------------------------------------------------------
# HOW TO USE
#   1. Fill in the empty values below.
#   2. Copy this file to ".env" locally  ->  cp .env.production.example .env
#   3. In Vercel: Project -> Settings -> Environment Variables -> Import .env
#      (select your "Production" + "Preview" environments), then deploy.
#   4. After the first deploy, seed the database once (see the bottom note).
#
# Lines starting with "#" are comments and are ignored by Vercel's importer.
# Quote any value that contains spaces (e.g. MAIL_FROM).
# =============================================================================

# --- Database: Turso (libSQL) -------------------------------------------------
# Create at https://turso.tech  ->  turso db create studio
#   turso db show studio --url        -> TURSO_DATABASE_URL (libsql://...)
#   turso db tokens create studio     -> TURSO_AUTH_TOKEN
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# --- File storage: Vercel Blob ------------------------------------------------
# Vercel -> Storage -> create a Blob store -> it auto-adds this token to the
# project. If you import manually, copy the token from the store's settings.
BLOB_READ_WRITE_TOKEN=

# --- Auth.js session secret ---------------------------------------------------
# A fresh random value has been generated for you. Regenerate any time with:
#   openssl rand -base64 32
AUTH_SECRET=5nC1g4f7AGhDRNnSmDs7h3165WtXgf3eNyuAy6gVymI=

# --- Email: Resend ------------------------------------------------------------
# https://resend.com -> verify your sending domain (SPF/DKIM) -> create API key.
# MAIL_FROM must be on the verified domain or mail won't send outside sandbox.
RESEND_API_KEY=
MAIL_FROM="Studio <delivery@yourdomain.com>"

# --- App URL ------------------------------------------------------------------
# Your canonical deployed URL (no trailing slash).
APP_URL=https://your-app.vercel.app

# --- Seed superadmin ----------------------------------------------------------
# Used once by `npm run db:seed` to create the first Principal (admin) login.
# Change the password before seeding, then change it again in-app after first login.
SUPERADMIN_EMAIL=admin@yourdomain.com
SUPERADMIN_PASSWORD=ChangeMe!123
SUPERADMIN_NAME=Principal Admin

# =============================================================================
# AFTER DEPLOY — run migrations + seed against your Turso DB (locally, once):
#   # put the same TURSO_* values in a local .env, then:
#   npm run db:migrate
#   npm run db:seed
# (SUPERADMIN_* and the seed are not needed as Vercel runtime vars — they're
#  only read by the one-off seed script. You can omit them from Vercel.)
# =============================================================================
