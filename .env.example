# Turso (libSQL). Leave unset to use a local SQLite file (file:./local.db).
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Vercel Blob store. Leave unset to use the local-disk fallback (./.localblob).
BLOB_READ_WRITE_TOKEN=

# Auth.js session secret — generate with: openssl rand -base64 32
AUTH_SECRET=dev-secret-change-me-0000000000000000000000

# Resend — outbound study email. Leave unset to log mail to the console in dev.
RESEND_API_KEY=
MAIL_FROM="Studio <delivery@example.com>"

# Canonical deployed URL
APP_URL=http://localhost:3000

# Seed superadmin (used by `npm run db:seed`)
SUPERADMIN_EMAIL=admin@studio.local
SUPERADMIN_PASSWORD=ChangeMe!123
SUPERADMIN_NAME=Principal Admin
